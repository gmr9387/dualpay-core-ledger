# DualPay Core Ledger — environment template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Supabase project reference ID (found in Project Settings → General)
VITE_SUPABASE_PROJECT_ID="your-project-ref-id"

# Supabase anon/publishable key (safe for browser; enforces RLS)
VITE_SUPABASE_PUBLISHABLE_KEY="******"

# Supabase project URL
VITE_SUPABASE_URL="https://your-project-ref-id.supabase.co"
